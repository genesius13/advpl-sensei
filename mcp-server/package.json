{
  "name": "@netoalmanca/advpl-sensei",
  "version": "1.1.5",
  "description": "MCP Server for ADVPL/TLPP Protheus ecosystem",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "advpl-sensei": "dist/index.js"
  },
  "files": [
    "dist",
    "agents",
    "commands",
    "skills"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --loader ts-node/esm src/index.ts",
    "test:phase5": "node --loader ts-node/esm src/__tests__/phase5-test.ts",
    "test:phase5-integration": "node --loader ts-node/esm src/__tests__/phase5-boilerplate-integration-test.ts",
    "test:phase6": "node --loader ts-node/esm src/__tests__/phase6-tdn-validation-test.ts",
    "test:phase8": "node --loader ts-node/esm src/__tests__/phase8-snippet-validation-test.ts",
    "test:phase9": "node --loader ts-node/esm src/__tests__/phase9-scraper-test.ts",
    "test:phase10": "node --loader ts-node/esm src/__tests__/phase10-mcp-validation-test.ts",
    "check:registry": "node --loader ts-node/esm src/__tests__/registry-quality-check.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.5.0",
    "js-yaml": "^4.1.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  },
  "repository": "https://github.com/genesius13/advpl-sensei.git"
}
